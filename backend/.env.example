NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/passop
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
JWT_COOKIE_DAYS=7
COOKIE_NAME=passop_token
ENCRYPTION_KEY=replace-with-a-64-character-hex-key
PASSWORD_HASH_KEY=replace-with-a-separate-32-character-random-secret
TRUST_PROXY=false
